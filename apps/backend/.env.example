# PostgreSQL connection
# DB_HOST points to the Docker-exposed port (docker compose up -d db); use localhost for the host-mapped 5432.
DB_HOST=localhost
DB_PORT=5432
DB_USER=myquiz
DB_PASSWORD=myquiz
DB_NAME=myquiz

# Application
PORT=3000

# JWT authentication
JWT_SECRET=change-me-before-production
JWT_EXPIRES_IN=7d
